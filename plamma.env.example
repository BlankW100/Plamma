# Plamma configuration
# Copy this file to plamma.env and edit as needed.
# plamma.env is loaded on startup and takes effect without restarting.
# Real environment variables always take priority over values here.

# ── Model ────────────────────────────────────────────────────────────────────
# Any model installed via `ollama pull` works.
# For full unrestricted functionality, use an abliterated or uncensored model.
# Examples:
#   huihui_ai/gemma-4-abliterated:latest
#   huihui_ai/qwen3-abliterated:latest
#   dolphin-llama3:latest
#   nous-hermes2:latest
#
PLAMMA_MODEL=huihui_ai/gemma-4-abliterated:latest

# ── Ollama ───────────────────────────────────────────────────────────────────
# Change if Ollama is running on a different host or port.
#
# OLLAMA_URL=http://localhost:11434

# ── Context window ───────────────────────────────────────────────────────────
# Number of tokens kept in the KV cache. Increase for longer conversations,
# decrease if you run out of VRAM.
#
# PLAMMA_CTX=2048

# ── Tor ports ────────────────────────────────────────────────────────────────
# Only change if you run Tor on non-standard ports.
#
# TOR_SOCKS_PORT=9050
# TOR_CONTROL_PORT=9051
